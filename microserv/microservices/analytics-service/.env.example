# Analytics Service Configuration
SERVICE_NAME=analytics-service
SERVICE_PORT=3006
ENVIRONMENT=development
LOG_LEVEL=info

# Database Configuration (Local Development)
DB_HOST=localhost
DB_PORT=3312
DB_USER=root
DB_PASSWORD=
DB_NAME=meditrack_analytics
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Connection Pool Settings
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Analytics Settings
DEFAULT_RETENTION_DAYS=90
BATCH_SIZE=1000

# Docker Compose Configuration (Uncomment for docker-compose)
# DB_HOST=mysql-analytics
# DB_PORT=3306
