# API Gateway Configuration
SERVICE_NAME=api-gateway
SERVICE_PORT=3000
ENVIRONMENT=development
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Microservices URLs (Local Development)
USER_SERVICE_URL=http://localhost:3001
APPOINTMENT_SERVICE_URL=http://localhost:3002
MEDICAL_SERVICE_URL=http://localhost:3003
PHARMACY_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
ANALYTICS_SERVICE_URL=http://localhost:3006

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=1m

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Docker Compose Configuration (Uncomment for docker-compose)
# USER_SERVICE_URL=http://user-service:3001
# APPOINTMENT_SERVICE_URL=http://appointment-service:3002
# MEDICAL_SERVICE_URL=http://medical-service:3003
# PHARMACY_SERVICE_URL=http://pharmacy-service:3004
# PAYMENT_SERVICE_URL=http://payment-service:3005
# ANALYTICS_SERVICE_URL=http://analytics-service:3006
