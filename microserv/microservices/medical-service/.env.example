# Medical Service Configuration
SERVICE_NAME=medical-service
SERVICE_PORT=3003
LOG_LEVEL=info
JWT_SECRET=your-secret-key-change-this

# Database Configuration (Local Development)
DB_HOST=localhost
DB_PORT=3309
DB_USER=root
DB_PASSWORD=
DB_NAME=meditrack_medical
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Connection Pool
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Inter-Service Communication (Local Development)
USER_SERVICE_URL=http://localhost:3001
APPOINTMENT_SERVICE_URL=http://localhost:3002

# Circuit Breaker Configuration
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30
REQUEST_TIMEOUT=5s

# Docker Compose Configuration
# DB_HOST=mysql-medical
# DB_PORT=3306
# USER_SERVICE_URL=http://user-service:3001
# APPOINTMENT_SERVICE_URL=http://appointment-service:3002
